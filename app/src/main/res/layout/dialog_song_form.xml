<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:text="Song Title *"
            android:textColor="#BB86FC"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/etSongTitle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_glass"
            android:hint="e.g. Unity"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#555577"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:text="Artist *"
            android:textColor="#BB86FC"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/etSongArtist"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_glass"
            android:hint="e.g. TheFatRat"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#555577"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:text="Category"
            android:textColor="#BB86FC"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/etSongCategory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_glass"
            android:hint="Chill / Workout / Focus / RB"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#555577"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:text="Audio URL (mp3)"
            android:textColor="#BB86FC"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/etAudioUrl"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_glass"
            android:hint="https://..."
            android:inputType="textUri"
            android:paddingHorizontal="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#555577"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:text="Cover Image URL"
            android:textColor="#BB86FC"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/etCoverUrl"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_input_glass"
            android:hint="https://..."
            android:inputType="textUri"
            android:paddingHorizontal="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#555577"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:text="Duration"
            android:textColor="#BB86FC"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/etDuration"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_input_glass"
            android:hint="e.g. 3:48"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#555577"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>