<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên bài hát *"
            android:textColor="#BB86FC"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etSongTitle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_item"
            android:hint="VD: Unity"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#66FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nghệ sĩ *"
            android:textColor="#BB86FC"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etSongArtist"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_item"
            android:hint="VD: TheFatRat"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#66FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thể loại"
            android:textColor="#BB86FC"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etSongCategory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_item"
            android:hint="Chill / Workout / Focus / RB"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#66FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="URL nhạc (mp3)"
            android:textColor="#BB86FC"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAudioUrl"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_item"
            android:hint="https://..."
            android:inputType="textUri"
            android:paddingHorizontal="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#66FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="URL ảnh bìa"
            android:textColor="#BB86FC"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etCoverUrl"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_item"
            android:hint="https://..."
            android:inputType="textUri"
            android:paddingHorizontal="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#66FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thời lượng"
            android:textColor="#BB86FC"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDuration"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_glass_item"
            android:hint="VD: 3:48"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#66FFFFFF"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>