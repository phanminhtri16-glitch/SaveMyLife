<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <!-- Animated glow circle behind logo -->

    <View
        android:id="@+id/glowCircle"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.3"
        android:background="@drawable/bg_glow_circle"
        app:layout_constraintBottom_toBottomOf="@id/ivSplashLogo"
        app:layout_constraintEnd_toEndOf="@id/ivSplashLogo"
        app:layout_constraintStart_toStartOf="@id/ivSplashLogo"
        app:layout_constraintTop_toTopOf="@id/ivSplashLogo" />


    <androidx.cardview.widget.CardView
        android:id="@+id/ivSplashLogo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="100dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="100dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toTopOf="@id/tvSplashName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.42"
        app:layout_constraintVertical_chainStyle="packed">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:scaleType="centerCrop"
            android:src="@drawable/yuxiaofy_logo" />
    </androidx.cardview.widget.CardView>

    <!--
    <ImageView
        android:id="@+id/ivSplashLogo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="100dp"
        android:background="@drawable/bg_circle_play"
        android:padding="16dp"
        android:src="@drawable/yuxiaofy_logo"
        app:layout_constraintBottom_toTopOf="@id/tvSplashName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.42"
        app:layout_constraintVertical_chainStyle="packed" /> -->

    <TextView
        android:id="@+id/tvSplashName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="130dp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.12"
        android:text="yuxiaofy"
        android:textColor="#FFFFFF"
        android:textSize="38sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivSplashLogo" />

    <TextView
        android:id="@+id/tvSplashTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:letterSpacing="0.1"
        android:text="Feel every beat"
        android:textColor="#BB86FC"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSplashName" />

    <!-- Loading dots -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="60dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ProgressBar
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminateTint="#BB86FC" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>