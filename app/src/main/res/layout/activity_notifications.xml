<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/notifContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="52dp"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_input_glass"
                android:padding="8dp"
                android:src="@android:drawable/ic_media_previous" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Notifications"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />
        </LinearLayout>

        <!-- MUSIC section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.15"
            android:text="MUSIC"
            android:textColor="#AAAACC"
            android:textSize="11sp" />

        <!-- New Releases -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_glass_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="New Releases"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Bài hát và album mới từ nghệ sĩ bạn theo dõi"
                    android:textColor="#AAAACC"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchNewReleases"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#BB86FC"
                android:trackTint="#442266" />
        </LinearLayout>

        <!-- Recommended -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_glass_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Recommended For You"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Gợi ý nhạc dựa trên thói quen nghe"
                    android:textColor="#AAAACC"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchRecommended"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#BB86FC"
                android:trackTint="#442266" />
        </LinearLayout>

        <!-- Playlist Update -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_glass_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Playlist Updates"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Khi playlist bạn theo dõi có bài mới"
                    android:textColor="#AAAACC"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchPlaylistUpdate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#BB86FC"
                android:trackTint="#442266" />
        </LinearLayout>

        <!-- GENERAL section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.15"
            android:text="GENERAL"
            android:textColor="#AAAACC"
            android:textSize="11sp" />

        <!-- Weekly Mix -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_glass_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Weekly Mix Ready"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Nhắc khi playlist hàng tuần của bạn sẵn sàng"
                    android:textColor="#AAAACC"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchWeeklyMix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#BB86FC"
                android:trackTint="#442266" />
        </LinearLayout>

        <!-- Promotions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_glass_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Promotions &amp; Offers"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Ưu đãi và thông báo từ Yuxiaofy"
                    android:textColor="#AAAACC"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchPromo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#BB86FC"
                android:trackTint="#442266" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>