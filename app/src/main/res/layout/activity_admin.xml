<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1A"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="32dp"
        android:background="#1A1A2E">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Panel"
            android:textColor="#BB86FC"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAdminName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Xin chào, Admin"
            android:textColor="#AAAAAA"
            android:textSize="13sp" />

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#2A2A3E"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginEnd="4dp">
                <TextView
                    android:id="@+id/tvTotalSongs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#BB86FC"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bài hát"
                    android:textColor="#888888"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#2A2A3E"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginStart="4dp">
                <TextView
                    android:id="@+id/tvTotalUsers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#03DAC6"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Người dùng"
                    android:textColor="#888888"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGoHome"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="#2A2A3E"
                android:text="Xem Home"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnAdminLogout"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="#FF4444"
                android:text="Đăng xuất"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnTabSongs"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Bài hát"
            android:textColor="#BB86FC"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnTabUsers"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Users"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btnTabStats"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Thống kê"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Tab: Songs -->
    <LinearLayout
        android:id="@+id/layoutSongs"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Search + Filter Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/etSearchSong"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="#1E1E2E"
                android:hint="Tìm bài hát..."
                android:textColorHint="#666688"
                android:inputType="text"
                android:paddingHorizontal="12dp"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/spinnerCategory"
                android:layout_width="120dp"
                android:layout_height="42dp"
                android:background="#1E1E2E" />
        </LinearLayout>

        <!-- Add + Count Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvSongCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 bài hát"
                android:textColor="#888888"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnAddSong"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="#BB86FC"
                android:text="+ Thêm"
                android:textColor="#000000"
                android:textSize="12sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAdminSongs"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- Tab: Users -->
    <LinearLayout
        android:id="@+id/layoutUsers"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/etSearchUser"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginBottom="8dp"
            android:background="#1E1E2E"
            android:hint="Tìm user theo tên hoặc email..."
            android:textColorHint="#666688"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvUserCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="0 người dùng"
            android:textColor="#888888"
            android:textSize="12sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAdminUsers"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- Tab: Stats -->
    <ScrollView
        android:id="@+id/layoutStats"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thống kê bài hát"
                android:textColor="#BB86FC"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView android:id="@+id/tvStatChill"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Chill: 0 bài" android:textColor="#FFFFFF"
                android:textSize="14sp" android:padding="10dp"
                android:background="#1E1E2E" android:layout_marginBottom="6dp" />

            <TextView android:id="@+id/tvStatWorkout"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Workout: 0 bài" android:textColor="#FFFFFF"
                android:textSize="14sp" android:padding="10dp"
                android:background="#1E1E2E" android:layout_marginBottom="6dp" />

            <TextView android:id="@+id/tvStatFocus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Focus: 0 bài" android:textColor="#FFFFFF"
                android:textSize="14sp" android:padding="10dp"
                android:background="#1E1E2E" android:layout_marginBottom="6dp" />

            <TextView android:id="@+id/tvStatRB"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="R&amp;B: 0 bài" android:textColor="#FFFFFF"
                android:textSize="14sp" android:padding="10dp"
                android:background="#1E1E2E" android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thống kê người dùng"
                android:textColor="#03DAC6"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView android:id="@+id/tvStatAdmins"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Admin: 0 người" android:textColor="#FFFFFF"
                android:textSize="14sp" android:padding="10dp"
                android:background="#1E1E2E" android:layout_marginBottom="6dp" />

            <TextView android:id="@+id/tvStatUsers"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="User: 0 người" android:textColor="#FFFFFF"
                android:textSize="14sp" android:padding="10dp"
                android:background="#1E1E2E" android:layout_marginBottom="6dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>